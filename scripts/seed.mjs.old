async function main() {
  const password = await hash("password123", 10);

  const buyer = await prisma.user.upsert({
    where: { email: "buyer@gocart.local" },
    update: {},
    create: {
      id: "user_buyer_1",
      name: "Buyer One",
      email: "buyer@gocart.local",
      image: "https://placehold.co/128x128",
      role: "BUYER",
      password,
    },
  });

  const seller = await prisma.user.upsert({
    where: { email: "seller@gocart.local" },
    update: {},
    create: {
      id: "user_seller_1",
      name: "Seller One",
      email: "seller@gocart.local",
      image: "https://placehold.co/128x128",
      role: "SELLER",
      password,
    },
  });

  const admin = await prisma.user.upsert({
    where: { email: "admin@gocart.local" },
    update: {},
    create: {
      id: "user_admin_1",
      name: "Admin One",
      email: "admin@gocart.local",
      image: "https://placehold.co/128x128",
      role: "ADMIN",
      password,
    },
  });

  const store = await prisma.store.upsert({
    where: { username: "happyshop" },
    update: {},
    create: {
      userId: seller.id,
      name: "Happy Shop",
      description: "Seeded demo store for GoCart",
      username: "happyshop",
      address: "123 Demo Street",
      status: "approved",
      isActive: true,
      logo: "https://placehold.co/256x256",
      email: "seller@gocart.local",
      contact: "+2340000000000",
    },
  });

  // Seed all products from dummy data
  for (const product of productDummyData) {
    await prisma.product.upsert({
      where: { id: product.id },
      update: {
        images: product.images,
      },
      create: {
        id: product.id,
        name: product.name,
        description: product.description,
        mrp: product.mrp,
        price: product.price,
        images: product.images,
        category: product.category,
        storeId: store.id,
        inStock: product.inStock,
      },
    });
  }

  const address = await prisma.address.upsert({
    where: { id: "addr_seed_1" },
    update: {},
    create: {
      id: "addr_seed_1",
      userId: buyer.id,
      name: "Buyer One",
      email: "buyer@gocart.local",
      street: "123 Demo Street",
      city: "Lagos",
      state: "LA",
      zip: "100001",
      country: "Nigeria",
      phone: "+2340000000001",
    },
  });

  await prisma.coupon.upsert({
    where: { code: "SEED10" },
    update: {},
    create: {
      code: "SEED10",
      description: "10% seed coupon",
      discount: 10,
      forNewUser: true,
      forMember: false,
      isPublic: true,
      expiresAt: new Date(now.getFullYear() + 1, now.getMonth(), now.getDate()),
    },
  });

  await prisma.order.upsert({
    where: { id: "order_seed_1" },
    update: {},
    create: {
      id: "order_seed_1",
      total: 75,
      userId: buyer.id,
      storeId: store.id,
      addressId: address.id,
      isPaid: true,
      paymentMethod: "COD",
      isCouponUsed: true,
      coupon: JSON.stringify({ code: "SEED10", discount: 10 }),
      orderItems: {
        create: [
          {
            productId: "prod_1",
            quantity: 1,
            price: 29,
          },
        ],
      },
    },
  });

  await prisma.rating.upsert({
    where: {
      userId_productId_orderId: {
        userId: buyer.id,
        productId: "prod_1",
        orderId: "order_seed_1",
      },
    },
    update: {},
    create: {
      rating: 5,
      review: "Great seeded product.",
      userId: buyer.id,
      productId: "prod_1",
      orderId: "order_seed_1",
    },
  });

  console.log("Seed completed");
}

main()
  .catch((error) => {
    console.error(error);
    process.exit(1);
  })
  .finally(async () => {
    await prisma.$disconnect();
  });
